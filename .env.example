# --- App ---
APP_ENV=development
DEBUG=true

# --- Backend ---
BACKEND_PORT=8000

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000

# --- Postgres ---
POSTGRES_USER=bloomberg
POSTGRES_PASSWORD=bloomberg
