# --- App ---
APP_ENV=development
DEBUG=true

# --- Backend ---
BACKEND_PORT=8000

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Postgres ---
POSTGRES_USER=bloomberg
POSTGRES_PASSWORD=bloomberg
POSTGRES_DB=bloomberg
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Meilisearch (filings full-text index) ---
MEILISEARCH_PORT=7700
MEILISEARCH_MASTER_KEY=bt-meili-dev-key

# --- Alpaca (market data + news + paper portfolio) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Anthropic (LLM synthesis: EXPLAIN / COMPARE) ---
ANTHROPIC_API_KEY=

# --- FRED (macro) ---
FRED_API_KEY=

# --- SEC EDGAR (required User-Agent per SEC policy) ---
SEC_USER_AGENT=bloomberg-terminal research@example.com

# --- GitHub OAuth (optional — Phase 6 auth) ---
# Register an OAuth app at https://github.com/settings/developers with
# callback URL "http://localhost:8000/api/auth/github/callback".
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session JWT signing key. Set a long random value in production so cookies
# survive backend restarts (otherwise a fresh dev key is generated on boot).
JWT_SECRET=

# --- FINRA TRACE (Phase 8 — corporate bond prints, optional) ---
# Free developer account at https://developer.finra.org/manage-credentials.
# Creates an OAuth2 client (key + secret); we use the client-credentials
# grant. Without these, /api/fixed_income/trace returns a 503 with a
# clear setup hint and the rest of the Fixed Income panel still works
# (Treasury auctions are public and require no key).
FINRA_API_KEY=
FINRA_API_SECRET=
