# ─────────────────────────────────────────────────────────────────────────────
# Railway environment variables for Bloomberg Terminal + AURORA
#
# Set these in the Railway dashboard under each service's "Variables" tab.
# Variables tagged "(reference)" are auto-injected by Railway plugins via
# variable references — see RAILWAY_DEPLOY.md for the exact reference
# syntax (e.g. ${{ Postgres.DATABASE_URL }}).
# ─────────────────────────────────────────────────────────────────────────────


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ BACKEND service                                                          │
# ╰──────────────────────────────────────────────────────────────────────────╯

# --- App identity / behaviour ---
APP_ENV=production
DEBUG=false

# --- Postgres (managed plugin) ---
# Auto-injected by the Railway Postgres plugin. Reference syntax:
#   DATABASE_URL=${{ Postgres.DATABASE_URL }}
# After provisioning, run once in Railway's Postgres shell:
#   CREATE EXTENSION IF NOT EXISTS timescaledb CASCADE;
DATABASE_URL=

# --- Redis (managed plugin) ---
# Auto-injected by the Railway Redis plugin:
#   REDIS_URL=${{ Redis.REDIS_URL }}
REDIS_URL=

# --- Meilisearch (Railway "Deploy from image" service) ---
# MEILISEARCH_URL points at the internal Railway hostname for the Meili
# service. Reference syntax: ${{ meilisearch.RAILWAY_PRIVATE_DOMAIN }}.
# MEILISEARCH_KEY must match MEILI_MASTER_KEY on the Meilisearch service.
MEILISEARCH_URL=http://meilisearch.railway.internal:7700
MEILISEARCH_KEY=replace-with-long-random-string

# --- Alpaca (market data + paper portfolio) ---
# Get keys at https://app.alpaca.markets/paper/dashboard/overview
# (Re-use the same Alpaca account already provisioned for Syntrackr.)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- FRED (macro data — free key) ---
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Finnhub (free tier covers basic equities) ---
# https://finnhub.io/dashboard
FINNHUB_API_KEY=

# --- FMP (free tier covers fundamentals fallback) ---
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# --- SEC EDGAR User-Agent ---
# SEC requires a contact email in the User-Agent string. Use a real
# mailbox you control — they'll email if you exceed rate limits.
SEC_USER_AGENT=bloomberg-terminal you@example.com

# --- Anthropic (Claude — AI advisor + EXPLAIN/COMPARE) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- GitHub OAuth (Phase 6 user accounts) ---
# Register an OAuth app at https://github.com/settings/developers with
# Authorization callback URL set to:
#   https://<backend-railway-url>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Frontend URL (used for CORS allow-list + OAuth post-login redirect) ---
# Set to the Railway-assigned public URL for the frontend service.
FRONTEND_URL=https://<frontend-railway-url>

# --- JWT session signing ---
# Long random secret. Generate with `openssl rand -hex 48`. Either name
# works — SECRET_KEY is preferred (matches the Railway convention) and
# JWT_SECRET is accepted for backwards compatibility with the docker
# image's existing env contract.
SECRET_KEY=

# --- FINRA TRACE (corporate bond prints — optional) ---
# https://developer.finra.org/manage-credentials
FINRA_API_KEY=
FINRA_API_SECRET=


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ FRONTEND service                                                         │
# ╰──────────────────────────────────────────────────────────────────────────╯

# Public URL of the backend service. The Vite build inlines this at compile
# time via `import.meta.env.VITE_API_URL`, so a redeploy is required after
# changing it.
VITE_API_URL=https://<backend-railway-url>


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ MEILISEARCH service (Docker image: getmeili/meilisearch:v1.7)            │
# ╰──────────────────────────────────────────────────────────────────────────╯

# Must match MEILISEARCH_KEY on the backend service.
MEILI_MASTER_KEY=replace-with-long-random-string
MEILI_NO_ANALYTICS=true
MEILI_ENV=production
